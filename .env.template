# ╔══════════════════════════════════════════════════════════════╗
# ║         KELAN SECURITY — Environment Template                ║
# ║  Copy to .env and fill in your values. NEVER commit .env.   ║
# ╚══════════════════════════════════════════════════════════════╝

# ── AI Engine — Local Ollama (no external API keys needed) ─────
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_TIMEOUT_SECS=60
OLLAMA_TEMPERATURE=0.1

# ── Database ───────────────────────────────────────────────────
# SQLite (default for local dev):
DATABASE_URL=sqlite+aiosqlite:///data/aitp.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql+asyncpg://kelan:<PASSWORD>@localhost/kelan

# ── Server ────────────────────────────────────────────────────
AITP_HTTP_PORT=3000
AITP_BIND_HOST=0.0.0.0

# ── Security (generate with: openssl rand -hex 32) ────────────
KELAN_JWT_SECRET=GENERATE_WITH_openssl_rand_hex_32

# ── eBPF / XDP ────────────────────────────────────────────────
KELAN_EBPF_ENABLED=true
KELAN_XDP_IFACE=eth0
SYN_RATE_LIMIT=50
UDP_RATE_LIMIT=200

# ── Post-Quantum ───────────────────────────────────────────────
REQUIRE_PQ=true

# ── Agentic WebSocket sync ────────────────────────────────────
AGENTIC_ENABLED=true
AGENT_SYNC_ENDPOINT=/ws/agent
# Token (generate with: openssl rand -hex 24)
AGENT_AUTH_TOKEN=GENERATE_WITH_openssl_rand_hex_24

# ── Monitoring (Grafana) ───────────────────────────────────────
# Generate with: openssl rand -base64 16
GRAFANA_PASSWORD=GENERATE_SECURE_RANDOM_PASSWORD

# ── Circuit Breaker ────────────────────────────────────────────
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT=30

# ── Alerts (optional) ─────────────────────────────────────────
ALERT_EMAIL=your@email.com
# Gmail App Password — create at https://myaccount.google.com/apppasswords
ALERT_EMAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
