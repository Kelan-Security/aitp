# ══════════════════════════════════════════════════
# KELAN SECURITY — .gitignore
# ══════════════════════════════════════════════════

# ── Rust ──────────────────────────────────────────
/target/
Cargo.lock.bak

# ── SECRETS — NEVER COMMIT ────────────────────────
.env
.env.*
!.env.example
!.env.template
*.prod
*.staging
*.local.env
secrets/
credentials/
google_credentials.json
service_account*.json

# ── Keys & Certificates ───────────────────────────
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
agent-identity.key
certs/server.crt
certs/server.key

# ── Kelan-specific config secrets ─────────────────
config/.env
config/.env.local
config/.env.production
!config/.env.example

# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
kelan-python/venv/
kelan-python/.venv/
kelan-python/.env
kelan-python/*.egg-info/
kelan-python/dist/
kelan-python/build/
.pytest_cache/
.ruff_cache/
*.egg-info/

# ── IDE ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ── Logs & Runtime ────────────────────────────────
*.log
logs/
.kelan.pid
:memory:

# ── Fuzzing ───────────────────────────────────────
fuzz/corpus/
fuzz/artifacts/

# ── Terraform ─────────────────────────────────────
deploy/oracle-cloud/terraform/terraform.tfvars
deploy/oracle-cloud/terraform/.terraform/
deploy/oracle-cloud/terraform/*.tfstate
deploy/oracle-cloud/terraform/*.tfstate.backup
deploy/oracle-cloud/terraform/.terraform.lock.hcl

# ── Build artifacts ───────────────────────────────
coverage/
reports/
*.profraw
*.profdata
