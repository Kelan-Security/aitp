# ══ Kelan Security — Environment Template ══════════════════════
# Copy to .env  ·  NEVER commit .env

# Server
AITP_HTTP_PORT=3000
AITP_HOST=0.0.0.0
AITP_DEBUG=false

# Database
DATABASE_URL=sqlite+aiosqlite:///data/kelan.db

# ── Ollama Local AI (replaces Gemini for offline/air-gapped deployments) ──
# Run: ollama serve  (on macOS host)
# Model pull: ollama pull qwen2.5:3b
#
# ═══════════════════════════════════════════════════
# OLLAMA MODEL — switch when upgrading hardware
# ═══════════════════════════════════════════════════

# ACTIVE (CPU, 8GB RAM, works now)
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_TIMEOUT_SECS=60

# UNCOMMENT when GPU machine is ready:
# OLLAMA_MODEL=gemma3:9b     # needs ~6GB VRAM — also set OLLAMA_TIMEOUT_SECS=15
# OLLAMA_MODEL=gemma3:27b    # needs ~18GB VRAM — also set OLLAMA_TIMEOUT_SECS=30
# OLLAMA_MODEL=mistral:7b    # needs ~5GB VRAM
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_TOKENS=300

# Security
KELAN_JWT_SECRET=GENERATE_openssl_rand_hex_32_HERE
REQUIRE_PQ=true

# Rate limits (eBPF XDP)
SYN_RATE_LIMIT=50
UDP_RATE_LIMIT=200

# Circuit breaker
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT=30

# Agentic sync
AGENTIC_ENABLED=true
