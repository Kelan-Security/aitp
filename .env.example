# ══ Kelan Security — Environment Template ══════════════════════
# Copy to .env  ·  NEVER commit .env

# Server
AITP_HTTP_PORT=3000
AITP_HOST=0.0.0.0
AITP_DEBUG=false

# Database
DATABASE_URL=sqlite+aiosqlite:///data/kelan.db

# ── Ollama LOCAL AI 
# Running on macOS M4 — zero cloud, zero API key
OLLAMA_ENDPOINT=http://YOUR_MAC_IP:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_TIMEOUT=90
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_TOKENS=300

# Security
KELAN_JWT_SECRET=GENERATE_openssl_rand_hex_32_HERE
REQUIRE_PQ=true

# Rate limits (eBPF XDP)
SYN_RATE_LIMIT=50
UDP_RATE_LIMIT=200

# Circuit breaker
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT=30

# Agentic sync
AGENTIC_ENABLED=true
