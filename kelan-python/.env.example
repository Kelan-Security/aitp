# ════════════════════════════════════════════
# Kelan Security — Environment Configuration
# Copy to .env and fill in your values
# ════════════════════════════════════════════

# ── Ollama AI Engine ─────────────────────────
# CURRENT model (CPU, works on any machine):
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_TIMEOUT_SECS=8.0
#
# FUTURE — uncomment when GPU machine is ready:
# OLLAMA_MODEL=gemma3:9b     # needs ~6GB VRAM
# OLLAMA_MODEL=gemma3:27b    # needs ~18GB VRAM
# OLLAMA_MODEL=mistral:7b    # needs ~5GB VRAM

# ── Database ──────────────────────────────────
# SQLite for dev (default):
DATABASE_URL=sqlite+aiosqlite:///./kelan.db
# PostgreSQL for production (uncomment):
# DATABASE_URL=postgresql+asyncpg://kelan:PASSWORD@localhost/kelan

# ── Security ──────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-generated-secret-minimum-32-chars

# ── Post-Quantum ──────────────────────────────
REQUIRE_PQ=false

# ── Server ────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# ── eBPF (set on Kali only, ignore on macOS) ──
XDP_INTERFACE=eth0
KELAN_SERVER_URL=http://localhost:3000
